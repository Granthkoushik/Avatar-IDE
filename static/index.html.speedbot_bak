<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AVATAR // AI-Powered Coding Workspace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Orbitron:wght@500;700;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <div class="stars"></div>
    <div class="hex-grid" aria-hidden="true"></div>

    <div class="app-shell">
      <!-- Top Header Bar -->
      <header class="top-bar">
        <div class="brand">
          <div class="logo-shield">
            <svg viewBox="0 0 24 24" class="shield-svg">
              <path d="M12 2L3 5v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V5l-9-3zm0 6c1.7 0 3 1.3 3 3s-1.3 3-3 3-3-1.3-3-3 1.3-3 3-3zm-5 8.5c0-1.8 3.3-2.5 5-2.5s5 .7 5 2.5V18H7v-3.5z" fill="currentColor"/>
            </svg>
          </div>
          <div class="brand-lockup">
              <strong class="avatar-wordmark">AVATAR</strong>
            <small>AI-POWERED CODING INTERFACE</small>
          </div>
        </div>

        <div class="global-search-pill">
          <span class="search-lightning">⚡</span>
          <input type="text" id="globalSearchInput" placeholder="Ask AVATAR anything... (Alt + K)" />
          <span class="search-command">Alt+K</span>
        </div>

        <div class="header-actions">
          <label class="select-wrap model-wrap">
            <span>AI Model</span>
            <select id="modelSelect">
              <option value="Avatar coding model">Avatar v2</option>
            </select>
          </label>
          <div class="status-pill online" id="aiStatus">
            <span class="status-dot"></span>
            <span>ONLINE</span>
          </div>
          <button class="icon-only-btn" type="button" title="View Workspace Settings">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          </button>
        </div>
      </header>

      <!-- Main Workspace Area -->
      <div class="workspace-grid">
        
        <!-- Left vertical ribbon bar -->
        <aside class="left-icon-ribbon">
          <div class="ribbon-top">
            <button class="ribbon-btn active" type="button" title="Explorer">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></button>
            <button class="ribbon-btn" type="button" title="Search Files">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg></button>
            <button class="ribbon-btn" id="ribbonChatBtn" type="button" title="Chat Room">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></button>
            <button class="ribbon-btn" type="button" title="Database Management">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"></path></svg></button>
            <button class="ribbon-btn" type="button" title="AI Diagnostics & Performance">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg></button>
          </div>
          <div class="ribbon-bottom">
            <button class="ribbon-btn" type="button" title="Workspace Settings">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg></button>
          </div>
        </aside>

        <!-- Left Sidebar panels -->
        <aside class="sidebar-panel">
          
          <!-- Project Explorer Section -->
          <div class="sidebar-section project-explorer-section">
            <div class="explorer-header">
              <div class="explorer-title-group">
                <h2>PROJECT EXPLORER</h2>
                <div class="project-selector-wrap">
                  <select id="projectSelect" class="clean-select">
                    <option value="neural-web-app">Neural Web App</option>
                  </select>
                </div>
              </div>
              <div class="explorer-toolbar">
                <button id="newFileBtn" type="button" title="New File">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                </button>
                <button id="newFolderBtn" type="button" title="New Folder">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path><line x1="12" y1="11" x2="12" y2="17"></line><line x1="9" y1="14" x2="15" y2="14"></line></svg>
                </button>
                <button id="uploadFileBtn" type="button" title="Upload File">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                </button>
                <button id="refreshWorkspaceBtn" type="button" title="Refresh Explorer">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                </button>
              </div>
            </div>
            <ul id="fileTree" class="file-tree">Loading workspace...</ul>
            <button class="gold fix-all-btn" id="fixProjectButton" type="button">⚡ Fix Entire Project</button>
          </div>

          
          

          <!-- Quick Actions Section -->
          <div class="sidebar-section quick-actions-section">
            <h2>QUICK ACTIONS</h2>
            <div class="actions-list">
              <button class="action-btn" type="button" id="actionNewFile">
                <span class="action-label">📄 New File</span>
                <span class="action-shortcut">Ctrl+N</span>
              </button>
              <button class="action-btn" type="button" id="actionFind">
                <span class="action-label">🔍 Find in Files</span>
                <span class="action-shortcut">Ctrl+Shift+F</span>
              </button>
              <button class="action-btn" type="button" id="actionGoTo">
                <span class="action-label">➡️ Go to Line</span>
                <span class="action-shortcut">Ctrl+G</span>
              </button>
            </div>
          </div>

          <!-- Avatar Bot Sidebar Card -->

        </aside>

        <!-- Main Column: Editor (Top) & Terminal (Bottom) -->
        <main class="main-column">
          
          <!-- Editor Section -->
          <section class="editor-zone">
            
            <!-- File Tabs and controls -->
            <div class="editor-tabs-container">
              <div class="editor-tabs" id="editorTabs"></div>
              <div class="editor-actions">
                <button class="editor-ctrl-btn run-btn" id="runCodeToolbarBtn" type="button" title="Run app.py (F5)">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </button>
                <button class="editor-ctrl-btn theme-btn" id="themeToggleBtn" type="button" title="Toggle Light/Dark Theme">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                </button>
                <button class="editor-ctrl-btn save-btn" id="saveToolbarButton" type="button" title="Save File (Ctrl+S)">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                </button>
                <button class="editor-ctrl-btn" type="button" title="More Actions">⋮</button>
              </div>
            </div>

            <!-- Monaco Editor Container -->
            <div id="editor"></div>

            <!-- Redesigned AVA Bot Companion (floating inside editor area) -->
            <div class="virtual-pet-container" id="virtualPetContainer">
              
              <!-- Speech bubble -->
              <div class="pet-bubble" id="petBubble">
                <div class="bubble-text">Hey! I'm AVATAR 👋<br>Drag me around, pet me, or ask me anything!</div>
              </div>

              <!-- Command input overlay -->
              <div class="pet-input-overlay hidden" id="petInputOverlay">
                <textarea id="petInputText" placeholder="Ask AVATAR anything... (Press Enter)"></textarea>
              </div>

              <!-- Character -->
              <div class="virtual-pet" id="virtualPet">
                <div class="pet-ears">
                  <div class="ear left-ear"><span class="ear-dot"></span></div>
                  <div class="ear right-ear"><span class="ear-dot"></span></div>
                </div>
                <div class="pet-head">
                  <div class="pet-screen">
                    <div class="pet-eye left-eye"><div class="pupil"></div></div>
                    <div class="pet-eye right-eye"><div class="pupil"></div></div>
                  </div>
                  <div class="pet-mouth"></div>
                </div>
                <div class="pet-sleep-z" id="petSleep">Zzz</div>
              </div>

              <!-- Holographic Glow Base -->
              <div class="holographic-base"></div>

              <!-- Floating quick controls -->
              <div class="pet-quick-controls">
                <button class="quick-control-btn" id="petInteractTickle" type="button" title="Tickle AVA">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v5"></path><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v6"></path><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8c0 4 3 7 7 7h1c3.3 0 6-2.7 6-6v-3a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2"></path></svg>
                </button>
                <button class="quick-control-btn drag-anchor" id="petInteractDrag" type="button" title="Drag Handle">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 9 2 12 5 15"></polyline><polyline points="9 5 12 2 15 5"></polyline><polyline points="15 19 12 22 9 19"></polyline><polyline points="19 9 22 12 19 15"></polyline><line x1="2" y1="12" x2="22" y2="12"></line><line x1="12" y1="2" x2="12" y2="22"></line></svg>
                </button>
                <button class="quick-control-btn" id="petInteractBlush" type="button" title="Tickle/Happy AVA">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
                </button>
              </div>
            </div>
          </section>

          <!-- Bottom Workspace Panel (Terminal, System overview) -->
          <section class="bottom-panel-zone">
            <div class="bottom-tabs-header">
              <div class="bottom-tabs">
                <button class="bottom-tab active" data-panel="terminal" type="button">TERMINAL</button>
                <button class="bottom-tab" data-panel="problems" type="button">PROBLEMS <span class="problem-count-badge" id="bottomProblemCount">2</span></button>
                <button class="bottom-tab" data-panel="output" type="button">OUTPUT</button>
                <button class="bottom-tab" data-panel="debug" type="button">DEBUG CONSOLE</button>
                <button class="bottom-tab" data-panel="requirements" type="button">REQUIREMENTS</button>
                <button class="bottom-tab" data-panel="progress" type="button">PROGRESS</button>
              </div>
              <div class="bottom-panel-actions">
                <button class="panel-act-btn" type="button" title="Add Terminal">+</button>
                <button class="panel-act-btn" type="button" title="Clear Panel" id="clearTerminalBtn">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </button>
                <button class="panel-act-btn" type="button" title="More Panel Settings">⋮</button>
              </div>
            </div>

            <div class="bottom-panels-content">
              <!-- Terminal content panel -->
              <div class="panel-view-content active" id="panelTerminal">
                <div class="terminal-stdout" id="terminalOutput">
                  <span class="term-prefix">avatar@devbox:~/Neural Web App$</span> python app.py<br>
                  <span class="term-dim">* Serving Flask app 'app'</span><br>
                  <span class="term-dim">* Debug mode: ON</span><br>
                  <span class="term-cyan">* Running on http://127.0.0.1:5000</span><br>
                  <span class="term-dim">* Restarting with stat</span><br>
                  <span class="term-green">* Debugger is active!</span><br>
                  <span class="term-dim">* Debugger PIN: 123-456-789</span><br>
                  <span class="term-cursor">|</span>
                </div>
              </div>

              <!-- Problems list panel -->
              <div class="panel-view-content" id="panelProblems">
                <div class="problems-list" id="problemsList">
                  <div class="problem-item critical">
                    <span class="prob-severity">CRITICAL</span>
                    <span class="prob-desc">Line 12: Missing imports for JSON serialization response</span>
                  </div>
                  <div class="problem-item low">
                    <span class="prob-severity">LOW</span>
                    <span class="prob-desc">Line 22: Redundant local variable 'processed'</span>
                  </div>
                </div>
              </div>

              <!-- Output content panel -->
              <div class="panel-view-content" id="panelOutput">
                <div class="logs-scroll" id="logs">
                  <div class="log-line">[info] Workspace successfully initialized.</div>
                </div>
              </div>

              <!-- Debug Console Panel -->
              <div class="panel-view-content" id="panelDebug">
                <div class="terminal-stdout">
                  <span class="term-dim">&gt; Debugger attached successfully. Listening for break interrupts...</span>
                </div>
              </div>

              <!-- Requirements Panel -->
              <div class="panel-view-content" id="panelRequirements">
                <div class="logs-scroll" id="requirementsContent">
                  <h3>Project Requirements</h3>
                  <div class="requirement-item">1. Streamline the workspace companion to act as the primary interface.</div>
                  <div class="requirement-item">2. Let the AI bot write and refactor code inside Monaco automatically.</div>
                  <div class="requirement-item">3. Monitor progress of current request in the Progress tab.</div>
                </div>
              </div>

              <!-- Progress Panel -->
              <div class="panel-view-content" id="panelProgress">
                <div class="logs-scroll" id="progressContent">
                  <div class="log-line">[info] Ready for command. Press Alt+K or two-finger click AVATAR to command AI.</div>
                </div>
              </div>
              
            </div>
          </section>
        </main>

        <!-- Right Column: AI Assistant panel removed (moved to bottom requirements pane) -->
      </div>

      <!-- Bottom Status Bar -->
      <footer class="bottom-bar">
        <div class="status-left">
          <span class="status-git-branch">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
            main
          </span>
          <span>Python 3.11.4</span>
          <span class="status-indicator-pair">
            <span class="status-indicator info">ℹ️ 0</span>
            <span class="status-indicator warn">⚠️ 2</span>
          </span>
        </div>
        
        <div class="status-center" id="footerStatusText">
          🤖 AVATAR is idle — pet me or ask me anything!
        </div>

        <div class="status-right">
          <span>Ln 1, Col 1</span>
          <span>Spaces: 4</span>
          <span>UTF-8</span>
          <span>LF</span>
          <span>Python</span>
          <span class="status-notifications">🔔</span>
        </div>
      </footer>
    </div>

    <!-- Hidden elements for state tracking -->
    <div class="hidden">
      <input type="text" id="saveFilenameInput" value="untitled.py" />
      <span id="streamStatus">Streaming: inactive</span>
      <span id="tokenSpeed">Tokens/s: --</span>
      <span id="processingState">Processing: idle</span>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs/loader.js"></script>
    <script src="/static/evaBot.js"></script>

<script src="/static/app.js"></script>
  </body>
</html>
